{
  "version": 2,
  "routes": [
    {
      "src": "/api/notion",
      "dest": "/api/notion.js"
    },
    {
      "src": "/api/tmdb",
      "dest": "/api/tmdb.js"
    }
  ]
}
{
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST" }
      ]
    }
  ]
}
